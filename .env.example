# NoneBot framework settings — read by nonebot.init(), NOT by config_loader.py.
# Bot business config lives in config.toml. Copy to .env and edit.

# FastAPI bind address (NoneBot HTTP server)
HOST=0.0.0.0
PORT=8080

# Admin QQ ids — authorize group admin tools and act as trusted sources
SUPERUSERS=["123456789"]

# OneBot V11 WebSocket — NapCat connection target
ONEBOT_WS_URLS=["ws://napcat:3001"]

# Optional: override [llm] block in config.toml. Env vars win over TOML.
# Leave commented if you set these in config.toml.
# LLM_BASE_URL=http://host.docker.internal:34567/v1
# LLM_API_KEY=sk-your-key
# LLM_MODEL=claude-sonnet-4-20250514
