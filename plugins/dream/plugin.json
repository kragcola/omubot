{
  "manifest_version": 3,
  "name": "dream",
  "display_name": {
    "zh": "梦境整理",
    "en": "Dream"
  },
  "description": "梦境整合：定期整理记忆卡片、清理表情包库",
  "version": "1.1.3",
  "priority": 150,
  "tier": "user",
  "toggle_policy": "runtime",
  "category": "ops",
  "permissions": [
    "tick",
    "storage",
    "network"
  ],
  "capabilities": [
    "memory_maintenance"
  ],
  "min_omubot_version": "",
  "config": {
    "defaults": "config.default.json",
    "schema": "config.schema.json",
    "apply_mode": "restart_required",
    "restart_required_fields": [
      "enabled",
      "life_reflection_enabled",
      "interval_hours",
      "max_rounds"
    ]
  },
  "store": {
    "visibility": "marketplace_ready",
    "marketplace_id": ""
  },
  "author": "Omubot"
}
