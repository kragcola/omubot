{
  "manifest_version": 3,
  "name": "slang",
  "display_name": {
    "zh": "群内黑话",
    "en": "Slang"
  },
  "description": "群内黑话：学习候选、审核后注入当前群语境",
  "version": "0.1.0",
  "priority": 42,
  "tier": "user",
  "toggle_policy": "runtime",
  "category": "expression",
  "permissions": [
    "message",
    "prompt",
    "tick",
    "tool",
    "storage",
    "network"
  ],
  "capabilities": [
    "slang_learning",
    "slang_lookup"
  ],
  "min_omubot_version": "",
  "config": {
    "defaults": "config.default.json",
    "schema": "config.schema.json",
    "apply_mode": "hot",
    "restart_required_fields": []
  },
  "store": {
    "visibility": "marketplace_ready",
    "marketplace_id": ""
  },
  "author": "Omubot"
}
