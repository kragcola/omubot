{
  "manifest_version": 3,
  "name": "bilibili",
  "display_name": {
    "zh": "B站识别",
    "en": "Bilibili"
  },
  "description": "B站视频链接识别：拉取标题、封面、简介并注入消息上下文",
  "version": "1.1.3",
  "priority": 190,
  "tier": "user",
  "toggle_policy": "runtime",
  "category": "tool",
  "permissions": [
    "message",
    "network"
  ],
  "capabilities": [
    "video_context"
  ],
  "min_omubot_version": "",
  "config": {
    "defaults": "config.default.json",
    "schema": "config.schema.json",
    "apply_mode": "restart_required",
    "restart_required_fields": [
      "enabled",
      "cache_ttl",
      "cover_timeout",
      "reply_mode",
      "bilibili_talk_value",
      "interest_llm_fallback",
      "high_interest_keywords",
      "medium_interest_keywords",
      "low_interest_keywords"
    ]
  },
  "store": {
    "visibility": "marketplace_ready",
    "marketplace_id": ""
  },
  "author": "Omubot"
}
