{
  "manifest_version": 3,
  "name": "debug_commands",
  "display_name": {
    "zh": "调试指令",
    "en": "Debug Commands"
  },
  "description": "调试指令增强：/plugins 查看已加载插件列表，/version 版本检查",
  "version": "1.3.1",
  "priority": 300,
  "tier": "user",
  "toggle_policy": "runtime",
  "category": "ops",
  "permissions": [
    "command"
  ],
  "capabilities": [
    "debug_commands"
  ],
  "min_omubot_version": "",
  "config": {
    "defaults": "config.default.json",
    "schema": "config.schema.json",
    "apply_mode": "restart_required",
    "restart_required_fields": [
      "plugins_command_enabled",
      "version_command_enabled",
      "max_reply_chars",
      "check_github_updates"
    ]
  },
  "store": {
    "visibility": "local",
    "marketplace_id": ""
  },
  "author": "Omubot"
}
