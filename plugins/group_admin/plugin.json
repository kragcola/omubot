{
  "manifest_version": 3,
  "name": "group_admin",
  "display_name": {
    "zh": "群管理工具",
    "en": "Group Admin"
  },
  "description": "群管理工具：禁言用户、设置头衔、发送群消息",
  "version": "1.1.1",
  "priority": 1,
  "tier": "user",
  "toggle_policy": "runtime",
  "category": "tool",
  "permissions": [
    "tool"
  ],
  "capabilities": [
    "group_admin_tools"
  ],
  "min_omubot_version": "",
  "config": {
    "defaults": "config.default.json",
    "schema": "config.schema.json",
    "apply_mode": "restart_required",
    "restart_required_fields": [
      "mute_enabled",
      "set_title_enabled",
      "send_group_msg_enabled",
      "default_mute_seconds",
      "max_mute_seconds"
    ]
  },
  "store": {
    "visibility": "local",
    "marketplace_id": ""
  },
  "author": "Omubot"
}
