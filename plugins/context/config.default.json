{
  "schema_version": 1,
  "plugin": "context",
  "values": {
    "enabled": true,
    "takeover_dynamic_prompt": true,
    "max_hits": 5,
    "max_doc_hits": 3,
    "max_chars": 2400,
    "graph_auto_extract": true,
    "rrf_k": 60,
    "rrf_weights": {
      "doc": 0.5,
      "memory": 0.3,
      "graph": 0.2
    },
    "use_token_budget": true,
    "budget": {
      "total_tokens": 6000,
      "memory_tokens": 1500,
      "doc_tokens": 2500,
      "graph_tokens": 1700,
      "buffer_tokens": 300
    }
  }
}
