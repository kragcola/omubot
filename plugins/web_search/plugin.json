{
  "manifest_version": 3,
  "name": "web_search",
  "display_name": {
    "zh": "网页搜索",
    "en": "Web Search"
  },
  "description": "网页搜索工具：搜索互联网，返回标题、链接和摘要",
  "version": "1.1.1",
  "priority": 1,
  "tier": "user",
  "toggle_policy": "runtime",
  "category": "tool",
  "permissions": [
    "tool",
    "network"
  ],
  "capabilities": [
    "web_search"
  ],
  "min_omubot_version": "",
  "config": {
    "defaults": "config.default.json",
    "schema": "config.schema.json",
    "apply_mode": "restart_required",
    "restart_required_fields": [
      "default_results",
      "max_results",
      "mode",
      "bing_market",
      "timeout_seconds"
    ]
  },
  "store": {
    "visibility": "local",
    "marketplace_id": ""
  },
  "author": "Omubot"
}
