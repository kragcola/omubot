{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "enabled": {
      "type": "boolean",
      "title": "启用日程心情"
    },
    "storage_dir": {
      "type": "string",
      "title": "日程目录"
    },
    "generate_at_hour": {
      "type": "integer",
      "title": "每日生成小时",
      "minimum": 0,
      "maximum": 23
    },
    "persona_driven_enabled": {
      "type": "boolean",
      "title": "角色驱动日程生成"
    },
    "story_arc_enabled": {
      "type": "boolean",
      "title": "启用 StoryArc 剧情弧账本"
    },
    "event_replan_enabled": {
      "type": "boolean",
      "title": "启用 L3 事件重规划闭环"
    },
    "dialogue_climate": {
      "type": "object",
      "title": "对话气候",
      "additionalProperties": true,
      "properties": {
        "m1_enabled": {
          "type": "boolean",
          "title": "启用 A-M1 tension 单维闭环"
        }
      }
    },
    "mood_anomaly_chance": {
      "type": "number",
      "title": "心情异常概率",
      "minimum": 0,
      "maximum": 1
    },
    "mood_refresh_minutes": {
      "type": "integer",
      "title": "心情刷新分钟",
      "minimum": 5
    }
  }
}
